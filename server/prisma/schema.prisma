generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  password                String
  createdAt               DateTime                 @default(now())
  isActive                Boolean                  @default(true)
  name                    String?
  teamId                  String?
  updatedAt               DateTime                 @updatedAt
  lastActive              DateTime?
  accountType             AccountType              @default(INDIVIDUAL)
  apiKeys                 ApiKey[]
  auditLogs               AuditLog[]
  firewalls               Firewall[]
  sentInvites             Invitation[]             @relation("InvitedBy")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  createdOrganizations    Organization[]           @relation("OrganizationCreator")
  organizationMemberships OrganizationMember[]
  sentTeamInvites         TeamInvite[]             @relation("InvitedBy")
  teamMemberships         TeamMember[]
  team                    Team?                    @relation(fields: [teamId], references: [id])
}

model Organization {
  id          String               @id @default(uuid())
  name        String
  uniqueId    String               @unique
  description String?
  plan        Plan                 @default(FREE)
  isActive    Boolean              @default(true)
  createdBy   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  firewalls   Firewall[]           @relation("OrganizationFirewalls")
  invitations Invitation[]
  creator     User                 @relation("OrganizationCreator", fields: [createdBy], references: [id])
  members     OrganizationMember[]
  teams       Team[]

  @@index([uniqueId])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           OrgRole      @default(MEMBER)
  joinedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Team {
  id             String       @id @default(uuid())
  name           String
  plan           Plan         @default(FREE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  description    String?
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invites        TeamInvite[]
  members        TeamMember[]
  oldMembers     User[]

  @@index([organizationId])
}

model TeamMember {
  id       String   @id @default(uuid())
  userId   String
  teamId   String
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([userId])
}

model Invitation {
  id             String         @id @default(uuid())
  email          String
  invitationType InvitationType
  organizationId String?
  role           OrgRole        @default(MEMBER)
  invitedBy      String
  token          String         @unique
  status         InviteStatus   @default(PENDING)
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  inviter        User           @relation("InvitedBy", fields: [invitedBy], references: [id])
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId, invitationType])
  @@index([token])
  @@index([email])
}

model Firewall {
  id             String        @id @default(uuid())
  name           String
  userId         String
  createdAt      DateTime      @default(now())
  description    String?
  isActive       Boolean       @default(true)
  updatedAt      DateTime      @updatedAt
  organizationId String?
  auditLogs      AuditLog[]
  organization   Organization? @relation("OrganizationFirewalls", fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])
  rules          Rule[]

  @@index([organizationId])
}

model Rule {
  id         String   @id @default(uuid())
  name       String
  type       RuleType
  pattern    String
  action     Action   @default(REDACT)
  priority   Int      @default(0)
  isActive   Boolean  @default(true)
  firewallId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  firewall   Firewall @relation(fields: [firewallId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String    @id @default(uuid())
  userId         String
  firewallId     String?
  inputText      String
  sanitizedText  String
  detectedIssues Json
  action         String
  aiProvider     String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  firewall       Firewall? @relation(fields: [firewallId], references: [id])
  user           User      @relation(fields: [userId], references: [id])
}

model ApiKey {
  id        String    @id @default(uuid())
  key       String    @unique
  name      String
  userId    String
  isActive  Boolean   @default(true)
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model TeamInvite {
  id        String   @id @default(uuid())
  email     String
  role      Role     @default(USER)
  teamId    String
  invitedBy String
  expiresAt DateTime
  createdAt DateTime @default(now())
  inviter   User     @relation("InvitedBy", fields: [invitedBy], references: [id])
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([email, teamId])
}

model Notification {
  id        String               @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  severity  NotificationSeverity @default(INFO)
  read      Boolean              @default(false)
  metadata  Json?
  createdAt DateTime             @default(now())
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model NotificationPreference {
  id          String   @id @default(uuid())
  userId      String
  category    String
  name        String
  description String
  email       Boolean  @default(true)
  push        Boolean  @default(false)
  slack       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OrgRole {
  MEMBER
  ADMIN
}

enum AccountType {
  INDIVIDUAL
  ORGANIZATION
}

enum InvitationType {
  ORGANIZATION
  TEAM
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum RuleType {
  EMAIL
  PHONE
  CREDIT_CARD
  SSN
  API_KEY
  IP_ADDRESS
  CUSTOM_REGEX
  PII
  CODE_SECRET
}

enum Action {
  REDACT
  MASK
  BLOCK
  WARN
  ALLOW
}

enum NotificationType {
  THREAT
  SECURITY
  TEAM
  BILLING
  SYSTEM
}

enum NotificationSeverity {
  CRITICAL
  WARNING
  INFO
}
